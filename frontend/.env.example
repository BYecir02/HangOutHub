# ──────────────────────────────────────────────────────────────
# Backend API
# ──────────────────────────────────────────────────────────────
# Base URL of the backend API.
# In local dev on a physical device, use your machine's LAN IP
# (not localhost) so the device can reach the backend, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.26:3000
EXPO_PUBLIC_API_URL=http://<YOUR_LAN_IP>:3000
