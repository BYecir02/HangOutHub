# ──────────────────────────────────────────────────────────────
# Database (Supabase / PostgreSQL)
# ──────────────────────────────────────────────────────────────
# Pooled connection (port 6543) used by the app at runtime
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) used by Prisma for migrations
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@<REGION>.pooler.supabase.com:5432/postgres"

# ──────────────────────────────────────────────────────────────
# Supabase API & Storage
# ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
# Server-side only — never expose this key to the client
SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY>
SUPABASE_STORAGE_BUCKET=hangouthub-media

# ──────────────────────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────────────────────
JWT_SECRET=<A_LONG_RANDOM_SECRET>

# ──────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────
PORT=3000

# ──────────────────────────────────────────────────────────────
# Email (Brevo)
# ──────────────────────────────────────────────────────────────
BREVO_API_KEY=<BREVO_API_KEY>
BREVO_SENDER_EMAIL=no-reply@joinhangouthub.com
BREVO_SENDER_NAME=HangOutHub
# Base URL used to build email verification links
EMAIL_VERIFY_BASE_URL=http://localhost:3000
# Optional: OTP verification TTL in minutes (default 10)
EMAIL_VERIFICATION_OTP_TTL_MINUTES=10
