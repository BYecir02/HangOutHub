generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp")]
}

model Booking {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String      @db.Uuid
  eventId      String?     @db.Uuid
  ticketTypeId String?     @db.Uuid
  clientRequestId String?  @db.VarChar(64)
  status       String?     @default("PENDING") @db.VarChar(20)
  qrCode       String?     @db.VarChar(255)
  Event        Event?      @relation(fields: [eventId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  TicketType   TicketType? @relation(fields: [ticketTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User         User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Payment      Payment[]

  @@unique([userId, eventId, clientRequestId])
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @db.VarChar(50)
  color String @default("#4c669f")
  icon  String @default("help-outline")
  animationUrl String? @db.VarChar(255)
  Tag   Tag[]
}

model ChatMessage {
  id       String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  outingId String    @db.Uuid
  senderId String    @db.Uuid
  content  String
  images   String[]  @default([])
  sentAt   DateTime? @default(now()) @db.Timestamp(6)
  Outing   Outing    @relation(fields: [outingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User     User      @relation(fields: [senderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model DirectConversation {
  id               String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userOneId        String         @db.Uuid
  userTwoId        String         @db.Uuid
  lastMessageAt    DateTime?      @db.Timestamp(6)
  userOneLastReadAt DateTime?     @db.Timestamp(6)
  userTwoLastReadAt DateTime?     @db.Timestamp(6)
  createdAt        DateTime?      @default(now()) @db.Timestamp(6)
  updatedAt        DateTime?      @updatedAt @db.Timestamp(6)
  UserOne          User           @relation("DirectConversationUserOne", fields: [userOneId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  UserTwo          User           @relation("DirectConversationUserTwo", fields: [userTwoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  DirectMessage    DirectMessage[]

  @@unique([userOneId, userTwoId])
  @@index([userOneId])
  @@index([userTwoId])
}

model DirectMessage {
  id             String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  conversationId String             @db.Uuid
  senderId       String             @db.Uuid
  clientId       String?            @db.VarChar(64)
  replyToMessageId String?          @db.Uuid
  sharedPostId   String?            @db.Uuid
  content        String
  images         String[]           @default([])
  deliveredAt    DateTime?          @db.Timestamp(6)
  readAt         DateTime?          @db.Timestamp(6)
  editedAt       DateTime?          @db.Timestamp(6)
  deletedAt      DateTime?          @db.Timestamp(6)
  isDeleted      Boolean            @default(false)
  sentAt         DateTime?          @default(now()) @db.Timestamp(6)
  Conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User           User               @relation(fields: [senderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ReplyToMessage DirectMessage?     @relation("DirectMessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  Replies        DirectMessage[]    @relation("DirectMessageReplies")
  SharedPost     Post?              @relation("DirectMessageSharedPost", fields: [sharedPostId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  Reactions      DirectMessageReaction[]

  @@index([conversationId, sentAt])
  @@index([senderId])
  @@index([replyToMessageId])
  @@index([sharedPostId])
  @@unique([conversationId, senderId, clientId])
}

model DirectMessageReaction {
  id        String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  messageId String        @db.Uuid
  userId    String        @db.Uuid
  emoji     String        @db.VarChar(16)
  createdAt DateTime?     @default(now()) @db.Timestamp(6)
  Message   DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User      User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([messageId, userId])
  @@index([userId])
}

model City {
  id               Int                @id @default(autoincrement())
  name             String             @unique @db.VarChar(100)
  slug             String             @unique @db.VarChar(100)
  imageUrl         String?            @db.VarChar(255)
  region           String?            @db.VarChar(100)
  country          String?            @db.VarChar(100)
  latitude         Float?
  longitude        Float?
  Event            Event[]
  Place            Place[]
  User             User[]
  UserCityInterest UserCityInterest[]
}

model DeviceToken {
  id       String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId   String  @db.Uuid
  token    String  @unique @db.VarChar(255)
  platform String? @db.VarChar(10)
  User     User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Event {
  id          String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  placeId     String?      @db.Uuid
  cityId      Int?
  organizerId String       @db.Uuid
  title       String       @db.VarChar(100)
  description String?
  startTime   DateTime     @db.Timestamp(6)
  endTime     DateTime?    @db.Timestamp(6)
  checkInOpensAtOffsetMin  Int? @default(-60)
  checkInClosesAtOffsetMin Int? @default(180)
  maxTicketsPerUser        Int? @default(1)
  cancellationPolicy String?
  refundPolicy       String?
  coverUrl    String?      @db.VarChar(255)
  entryFee    Decimal?     @default(0) @db.Decimal(10, 2)
  images      String[]     @default([])
  address     String?      @db.VarChar(255)
  Booking     Booking[]
  User        User         @relation(fields: [organizerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Place       Place?       @relation(fields: [placeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  City        City?        @relation(fields: [cityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  EventTag    EventTag[]
  EventCollaborator EventCollaborator[]
  EventRevision EventRevision[]
  Promotion   Promotion[]
  TicketType  TicketType[]
  Post        Post[]
}

model EventRevision {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  eventId     String    @db.Uuid
  actorUserId String?   @db.Uuid
  action      String    @db.VarChar(32)
  snapshot    Json
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  Event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Actor       User?     @relation("EventRevisionActor", fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([eventId, createdAt])
  @@index([actorUserId])
}

model EventCollaborator {
  eventId    String    @db.Uuid
  userId     String    @db.Uuid
  permission String?   @default("EDIT") @db.VarChar(16)
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  Event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([eventId, userId])
  @@index([userId])
}

model EventTag {
  eventId String @db.Uuid
  tagId   Int
  Event   Event  @relation(fields: [eventId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Tag     Tag    @relation(fields: [tagId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([eventId, tagId])
}

model Friendship {
  id                                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  requesterId                       String    @db.Uuid
  receiverId                        String    @db.Uuid
  status                            String?   @default("PENDING") @db.VarChar(20)
  createdAt                         DateTime? @default(now()) @db.Timestamp(6)
  User_Friendship_receiverIdToUser  User      @relation("Friendship_receiverIdToUser", fields: [receiverId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User_Friendship_requesterIdToUser User      @relation("Friendship_requesterIdToUser", fields: [requesterId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Notification {
  id                              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId                          String    @db.Uuid
  actorId                         String?   @db.Uuid
  type                            String    @db.VarChar(50)
  title                           String?   @db.VarChar(120)
  message                         String?
  severity                        String?   @default("INFO") @db.VarChar(16)
  payload                         Json?
  targetPath                      String?   @db.VarChar(255)
  isRead                          Boolean?  @default(false)
  createdAt                       DateTime? @default(now()) @db.Timestamp(6)
  User_Notification_actorIdToUser User?     @relation("Notification_actorIdToUser", fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User_Notification_userIdToUser  User      @relation("Notification_userIdToUser", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, isRead, createdAt])
  @@index([userId, type, createdAt])
}

model Outing {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  creatorId         String              @db.Uuid
  placeId           String?             @db.Uuid
  title             String              @db.VarChar(100)
  scheduledDate     DateTime            @db.Timestamp(6)
  status            String?             @default("DRAFT") @db.VarChar(20)
  ChatMessage       ChatMessage[]
  User              User                @relation(fields: [creatorId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Place             Place?              @relation(fields: [placeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  OutingMedia       OutingMedia[]
  OutingParticipant OutingParticipant[]
}

model OutingMedia {
  id                 String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  outingId           String               @db.Uuid
  uploaderId         String               @db.Uuid
  url                String               @db.VarChar(255)
  type               String?              @db.VarChar(10)
  createdAt          DateTime?            @default(now()) @db.Timestamp(6)
  Outing             Outing               @relation(fields: [outingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User               User                 @relation(fields: [uploaderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  OutingMediaComment OutingMediaComment[]
  OutingMediaLike    OutingMediaLike[]
}

model OutingMediaComment {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String      @db.Uuid
  mediaId     String      @db.Uuid
  content     String
  OutingMedia OutingMedia @relation(fields: [mediaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User        User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model OutingMediaLike {
  userId      String      @db.Uuid
  mediaId     String      @db.Uuid
  OutingMedia OutingMedia @relation(fields: [mediaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User        User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, mediaId])
}

model OutingParticipant {
  outingId String   @db.Uuid
  userId   String   @db.Uuid
  status   String?  @default("INVITED") @db.VarChar(20)
  isAdmin  Boolean? @default(false)
  chatLastReadAt DateTime? @db.Timestamp(6)
  Outing   Outing   @relation(fields: [outingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User     User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([outingId, userId])
}

model Payment {
  id        String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bookingId String  @db.Uuid
  amount    Decimal @db.Decimal(10, 2)
  provider  String  @db.VarChar(50)
  status    String? @default("PENDING") @db.VarChar(20)
  Booking   Booking @relation(fields: [bookingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Permission {
  id             Int              @id @default(autoincrement())
  slug           String           @unique @db.VarChar(50)
  description    String?          @db.VarChar(255)
  RolePermission RolePermission[]
}

model Place {
  id           String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cityId       Int
  ownerId      String?        @db.Uuid // ✅ Le propriétaire du lieu
  name         String         @db.VarChar(100)
  category     String?        @db.VarChar(32)
  description  String?
  address      String?        @db.VarChar(255)
  phone        String?        @db.VarChar(30)
  whatsapp     String?        @db.VarChar(30)
  openingHours String?        @db.VarChar(255)
  latitude     Float
  longitude    Float
  priceLevel   Int?           @default(1)
  moderationStatus String     @default("PENDING") @db.VarChar(32)
  externalProvider String?    @db.VarChar(32)
  externalProviderId String?   @db.VarChar(255)
  externalUrl   String?        @db.VarChar(500)
  providerLatitude Float?
  providerLongitude Float?
  providerMatchConfidence Float? @default(0)
  providerMatchedAt DateTime?  @db.Timestamp(6)
  coverUrl     String?        @db.VarChar(255)
  avgRating    Float?         @default(0)
  viewCount    Int?           @default(0)
  images       String[]       @default([])
  createdAt    DateTime       @default(now()) @db.Timestamp(6)
  updatedAt    DateTime?      @updatedAt @db.Timestamp(6)
  Event        Event[]
  Outing       Outing[]
  City         City           @relation(fields: [cityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Owner        User?          @relation("PlaceOwner", fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  PlaceClaim   PlaceClaim[]
  PlaceTag     PlaceTag[]
  PlaceTeamMember PlaceTeamMember[]
  Promotion    Promotion[]
  Review       Review[]
  SavedPlace   SavedPlace[]
  Story        Story[]
  Subscription Subscription[]
  Post         Post[]

}

model PlaceTeamMember {
  placeId    String    @db.Uuid
  userId     String    @db.Uuid
  role       String?   @default("STAFF") @db.VarChar(20)
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  Place      Place     @relation(fields: [placeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([placeId, userId])
  @@index([userId])
}

model PlaceClaim {
  id          String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String  @db.Uuid
  placeId     String  @db.Uuid
  documentUrl String  @db.VarChar(255)
  status      String? @default("PENDING") @db.VarChar(20)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime? @updatedAt @db.Timestamp(6)
  Place       Place   @relation(fields: [placeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User        User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([placeId, userId])
  @@index([placeId, status])
  @@index([userId])
}

model PlaceTag {
  placeId String @db.Uuid
  tagId   Int
  Place   Place  @relation(fields: [placeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Tag     Tag    @relation(fields: [tagId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([placeId, tagId])
}

model Promotion {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  placeId        String?   @db.Uuid
  eventId        String?   @db.Uuid
  budget         Decimal?  @db.Decimal(10, 2)
  endDate        DateTime? @db.Timestamp(6)
  code           String?   @db.VarChar(32)
  discountType   String?   @default("PERCENT") @db.VarChar(16)
  discountValue  Decimal?  @db.Decimal(10, 2)
  maxRedemptions Int?
  redeemedCount  Int?      @default(0)
  Event          Event?    @relation(fields: [eventId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Place          Place?    @relation(fields: [placeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([eventId, code])
}

model Post {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId     String    @db.Uuid
  content    String?
  images     String[]  @default([])
  publicationScope String? @default("personal") @db.VarChar(20)
  visibility String?   @default("public") @db.VarChar(20)
  postType   String?   @default("post") @db.VarChar(20)
  visibilityUserIds String[] @default([])
  placeId    String?   @db.Uuid
  eventId    String?   @db.Uuid
  placeName  String?   @db.VarChar(120)
  cityName   String?   @db.VarChar(120)
  ambiance   String?   @db.VarChar(50)
  shareCount Int       @default(0)
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedAt  DateTime? @updatedAt @db.Timestamp(6)
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Place      Place?    @relation(fields: [placeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Event      Event?    @relation(fields: [eventId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  comments   PostComment[]
  likes      PostLike[]
  SharedDirectMessage DirectMessage[] @relation("DirectMessageSharedPost")
  PostShareEvent PostShareEvent[]

  @@index([visibilityUserIds], type: Gin)
}

model PostShareEvent {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  postId    String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamp(6)
  Post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model UserFlowEvent {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  distinctId        String   @db.VarChar(80)
  sessionId         String   @db.VarChar(80)
  userId            String?  @db.Uuid
  eventName         String   @db.VarChar(64)
  actionName        String?  @db.VarChar(120)
  screenKey         String?  @db.VarChar(180)
  screenName        String?  @db.VarChar(120)
  path              String?  @db.VarChar(255)
  previousScreenKey String?  @db.VarChar(180)
  previousPath      String?  @db.VarChar(255)
  entityType        String?  @db.VarChar(64)
  entityId          String?  @db.VarChar(64)
  platform          String?  @db.VarChar(20)
  appVersion        String?  @db.VarChar(20)
  buildChannel      String?  @db.VarChar(30)
  locale            String?  @db.VarChar(16)
  metadata          Json?
  createdAt         DateTime @default(now()) @db.Timestamp(6)
  User              User?    @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([createdAt])
  @@index([screenKey, createdAt])
  @@index([eventName, createdAt])
  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
}

model Report {
    id         String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    reporterId String  @db.Uuid
    targetId   String  @db.Uuid
    targetType String  @db.VarChar(30)
    reason     String  @db.VarChar(255)
    status     String? @default("PENDING") @db.VarChar(20)
    createdAt  DateTime @default(now()) @db.Timestamp(6)
    actionTaken String? @db.VarChar(40)
    moderatorNote String? @db.VarChar(255)
    resolvedByUserId String? @db.Uuid
    resolvedAt DateTime? @db.Timestamp(6)
    User       User    @relation(fields: [reporterId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  }

model Review {
  id            String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId        String          @db.Uuid
  placeId       String          @db.Uuid
  rating        Int
  comment       String?
  photos        String?
  createdAt     DateTime?       @default(now()) @db.Timestamp(6)
  Place         Place           @relation(fields: [placeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User          User            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ReviewComment ReviewComment[]
  ReviewLike    ReviewLike[]
}

model ReviewComment {
  id       String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId   String @db.Uuid
  reviewId String @db.Uuid
  content  String
  Review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User     User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ReviewLike {
  userId   String @db.Uuid
  reviewId String @db.Uuid
  Review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User     User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, reviewId])
}

model Role {
  id             Int              @id @default(autoincrement())
  name           String           @unique @db.VarChar(50)
  description    String?          @db.VarChar(255)
  RolePermission RolePermission[]
  UserRole       UserRole[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  Permission   Permission @relation(fields: [permissionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Role         Role       @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([roleId, permissionId])
}

model SavedPlace {
  userId  String    @db.Uuid
  placeId String    @db.Uuid
  savedAt DateTime? @default(now()) @db.Timestamp(6)
  Place   Place     @relation(fields: [placeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User    User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, placeId])
}

model Story {
  id        String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String      @db.Uuid
  placeId   String?     @db.Uuid
  mediaUrl  String      @db.VarChar(255)
  expiresAt DateTime    @db.Timestamp(6)
  Place     Place?      @relation(fields: [placeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User      User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  StoryLike StoryLike[]
  StoryView StoryView[]
}

model StoryLike {
  userId  String @db.Uuid
  storyId String @db.Uuid
  Story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User    User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, storyId])
}

model StoryView {
  userId  String    @db.Uuid
  storyId String    @db.Uuid
  seenAt  DateTime? @default(now()) @db.Timestamp(6)
  Story   Story     @relation(fields: [storyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User    User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, storyId])
}

model Subscription {
  id       String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  placeId  String    @db.Uuid
  planName String?   @db.VarChar(50)
  endDate  DateTime? @db.Timestamp(6)
  Place    Place     @relation(fields: [placeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Tag {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(50)
  categoryId      Int?
  status          String            @default("APPROVED") @db.VarChar(16)
  submittedByUserId String?         @db.Uuid
  EventTag        EventTag[]
  PlaceTag        PlaceTag[]
  Category        Category?         @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  UserTagInterest UserTagInterest[]

  @@index([categoryId, status])
  @@index([submittedByUserId])
}

model TicketType {
  id       String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  eventId  String    @db.Uuid
  name     String    @db.VarChar(50)
  description String?
  price    Decimal   @db.Decimal(10, 2)
  quantity Int
  Booking  Booking[]
  Event    Event     @relation(fields: [eventId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model PostComment {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  postId    String    @db.Uuid
  userId    String    @db.Uuid
  content   String
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  parentId  String?   @db.Uuid
  Post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Parent    PostComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  Replies   PostComment[] @relation("CommentReplies")
}

model PostLike {
  userId String @db.Uuid
  postId String @db.Uuid
  Post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  User   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

model OrganizerProfile {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String   @unique @db.Uuid
  accountType String   @db.VarChar(20) // "PLACE" (Lieu physique) ou "NOMAD" (Promoteur)
  companyName String   @db.VarChar(100)
  ifuNumber   String   @db.VarChar(50) // Identifiant Fiscal Unique
  payoutInfo  String   @db.VarChar(100) // Numéro Mobile Money ou IBAN
  jobTitle    String   @db.VarChar(50) // Patron, Manager, Chargé de Com'
  instagramUrl String? @db.VarChar(255)
  tiktokUrl    String? @db.VarChar(255)
  facebookUrl  String? @db.VarChar(255)
  xUrl         String? @db.VarChar(255)
  websiteUrl   String? @db.VarChar(255)
  status      String   @default("PENDING") @db.VarChar(20) // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @db.Timestamp(6)
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique // On stocke le token (ou un hash) pour pouvoir le révoquer
  refreshTokenHash String?  @unique @db.VarChar(255)
  expiresAt DateTime? @db.Timestamp(6)
  lastUsedAt DateTime? @db.Timestamp(6)
  revokedAt DateTime? @db.Timestamp(6)
  device    String?  @db.VarChar(100) // Ex: "iPhone 13", "Android"
  createdAt DateTime @default(now()) @db.Timestamp(6)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id                               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId                           String   @unique @db.Uuid
  notificationMessages             Boolean  @default(true)
  notificationOutingInvites        Boolean  @default(true)
  notificationFriendRequests       Boolean  @default(true)
  notificationSavedPlacesActivity  Boolean  @default(true)
  organizerNotifyBookings          Boolean  @default(true)
  organizerNotifyTeamUpdates       Boolean  @default(true)
  organizerNotifyReminderD1        Boolean  @default(true)
  organizerNotifyReminderH3        Boolean  @default(true)
  organizerNotifyReminderH1        Boolean  @default(true)
  organizerReminderMode            String   @default("preset") @db.VarChar(16)
  organizerReminderOffsetsMin      Int[]    @default([])
  organizerNotificationPriorityMin String   @default("IMPORTANT") @db.VarChar(16)
  organizerScannerOfflineAuto      Boolean  @default(true)
  organizerScannerAutoSync         Boolean  @default(true)
  organizerScannerHaptics          Boolean  @default(true)
  organizerScannerSound            Boolean  @default(true)
  organizerScannerStrictWindow     Boolean  @default(true)
  organizerDefaultCheckInOpenOffsetMin  Int  @default(-60)
  organizerDefaultCheckInCloseOffsetMin Int  @default(180)
  organizerDefaultMaxTicketsPerUser     Int  @default(1)
  organizerDefaultCancellationPolicy    String?
  organizerDefaultRefundPolicy          String?
  organizerTeamInviteScope         String   @default("OWNER_ONLY") @db.VarChar(24)
  organizerTeamDefaultPermission   String   @default("EDIT") @db.VarChar(16)
  organizerTeamRequireRemovalConfirm Boolean @default(true)
  profilePublic                    Boolean  @default(true)
  defaultPostVisibility            String   @default("public") @db.VarChar(20)
  allowOutingInvitesFrom           String   @default("connections") @db.VarChar(20)
  theme                            String   @default("system") @db.VarChar(20)
  language                         String   @default("fr") @db.VarChar(10)
  dataSaver                        Boolean  @default(false)
  createdAt                        DateTime @default(now()) @db.Timestamp(6)
  updatedAt                        DateTime @updatedAt @db.Timestamp(6)
  User                             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                                      String               @id @default(uuid()) @db.Uuid
  username                                String               @unique @db.VarChar(50)
  phoneNumber                             String               @unique @db.VarChar(20)
  email                                   String?              @unique @db.VarChar(255)
  displayName                             String?              @db.VarChar(100)
  isSuspended                            Boolean              @default(false)
  passwordHash                            String?              @db.VarChar(255)
  isVerified                              Boolean?             @default(false)
  emailVerifiedAt                         DateTime?            @db.Timestamp(6)
  bio                                     String?
  avatarUrl                               String?              @db.VarChar(255)
  coverUrl                                String?              @db.VarChar(255)
  birthDate                               DateTime?            @db.Date
  gender                                  String?              @db.VarChar(20)
  residenceCityId                         Int?
  followersCount                          Int?                 @default(0)
  followingCount                          Int?                 @default(0)
  isActive                                Boolean?             @default(true)
  lastLoginAt                             DateTime?            @db.Timestamp(6)
  createdAt                               DateTime?            @default(now()) @db.Timestamp(6)
  updatedAt                               DateTime?            @updatedAt @db.Timestamp(6)
  Booking                                 Booking[]
  ChatMessage                             ChatMessage[]
  DirectConversationAsUserOne             DirectConversation[] @relation("DirectConversationUserOne")
  DirectConversationAsUserTwo             DirectConversation[] @relation("DirectConversationUserTwo")
  DirectMessage                           DirectMessage[]
  DirectMessageReaction                   DirectMessageReaction[]
  DeviceToken                             DeviceToken[]
  Event                                   Event[]
  EventCollaborator                       EventCollaborator[]
  EventRevisionActor                      EventRevision[]      @relation("EventRevisionActor")
  Friendship_Friendship_receiverIdToUser  Friendship[]         @relation("Friendship_receiverIdToUser")
  Friendship_Friendship_requesterIdToUser Friendship[]         @relation("Friendship_requesterIdToUser")
  Notification_Notification_actorIdToUser Notification[]       @relation("Notification_actorIdToUser")
  Notification_Notification_userIdToUser  Notification[]       @relation("Notification_userIdToUser")
  Outing                                  Outing[]
  OutingMedia                             OutingMedia[]
  OwnedPlaces                             Place[]              @relation("PlaceOwner") // ✅ Liste des lieux possédés
  Post                                    Post[]
  PostShareEvent                          PostShareEvent[]
  PostComment                             PostComment[]
  PostLike                                PostLike[]
  OutingMediaComment                      OutingMediaComment[]
  OutingMediaLike                         OutingMediaLike[]
  OutingParticipant                       OutingParticipant[]
  PlaceClaim                              PlaceClaim[]
  PlaceTeamMember                         PlaceTeamMember[]
  Report                                  Report[]
  Review                                  Review[]
  ReviewComment                           ReviewComment[]
  ReviewLike                              ReviewLike[]
  SavedPlace                              SavedPlace[]
  Story                                   Story[]
  StoryLike                               StoryLike[]
  StoryView                               StoryView[]
  City                                    City?                @relation(fields: [residenceCityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  UserCityInterest                        UserCityInterest[]
  OrganizerProfile                        OrganizerProfile?
  Session                                 Session[]
  UserSettings                            UserSettings?
  UserRole                                UserRole[]
  UserTagInterest                         UserTagInterest[]
  UserFlowEvents                          UserFlowEvent[]
  EmailVerificationToken                  EmailVerificationToken[]
  PasswordResetToken                      PasswordResetToken[]
}

model EmailVerificationToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @db.VarChar(128)
  expiresAt  DateTime  @db.Timestamp(6)
  usedAt     DateTime? @db.Timestamp(6)
  createdAt  DateTime  @default(now()) @db.Timestamp(6)
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @db.VarChar(128)
  expiresAt  DateTime  @db.Timestamp(6)
  usedAt     DateTime? @db.Timestamp(6)
  createdAt  DateTime  @default(now()) @db.Timestamp(6)
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model UserCityInterest {
  userId String @db.Uuid
  cityId Int
  City   City   @relation(fields: [cityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, cityId])
}

model UserRole {
  userId     String    @db.Uuid
  roleId     Int
  assignedAt DateTime? @default(now()) @db.Timestamp(6)
  Role       Role      @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, roleId])
}

model UserTagInterest {
  userId String @db.Uuid
  tagId  Int
  Tag    Tag    @relation(fields: [tagId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, tagId])
}
